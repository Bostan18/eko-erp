# Copier ce fichier en .env et remplir les valeurs
# Ne jamais commiter .env dans git

# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changez-moi-avec-une-cle-aleatoire-de-50-caracteres-minimum

# True en développement uniquement — False obligatoire en production
DEBUG=False

# Séparé par virgules — ex: mondomaine.ci,www.mondomaine.ci
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=eko_erp
DB_USER=eko_user
DB_PASSWORD=votre_mot_de_passe_fort
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/1

# CORS — origines React autorisées (séparées par virgules)
CORS_ALLOWED_ORIGINS=http://localhost:5173
